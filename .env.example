# Copy to .env.local for local development. NEVER commit real values.

# --- Next.js (.env.local / Vercel) ---

# Convex deployment URL (written into .env.local by `npx convex dev`).
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Dev deployment identifier used by `npx convex dev` (written automatically).
CONVEX_DEPLOYMENT=dev:your-deployment

# Anthropic API key — server-only, used by the chat backend (Vercel env).
ANTHROPIC_API_KEY=sk-ant-...

# Optional chat model override (defaults to claude-opus-4-8).
CHAT_MODEL=claude-opus-4-8

# --- Convex deployment env vars ---
# These live on the Convex deployment, NOT in this file. Set them with:
#   npx convex env set KEY value
#
#   SITE_URL                 http://localhost:3000 (or your production URL)
#   JWT_PRIVATE_KEY          generated by the @convex-dev/auth setup (npx @convex-dev/auth)
#   JWKS                     generated by the @convex-dev/auth setup
#   FOOTBALL_DATA_API_KEY    football-data.org API key (fixtures/results issues)
#   ODDS_API_KEY             the-odds-api.com API key (odds issue)
